{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SkillLord Hooks Configuration",
  "type": "object",
  "properties": {
    "$schema": { "type": "string" },
    "hooks": {
      "type": "object",
      "patternProperties": {
        "^(PreToolUse|PostToolUse|Stop|Notification|SubagentStop)$": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["hooks"],
            "properties": {
              "matcher": { "type": "string" },
              "description": { "type": "string" },
              "hooks": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["type", "command"],
                  "properties": {
                    "type": { "type": "string", "enum": ["command"] },
                    "command": { "type": "string" },
                    "timeout": { "type": "number" },
                    "async": { "type": "boolean" }
                  },
                  "additionalProperties": false
                },
                "minItems": 1
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "required": ["hooks"],
  "additionalProperties": true
}
