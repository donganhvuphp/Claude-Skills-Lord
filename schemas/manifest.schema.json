{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SkillLord Skills Manifest",
  "type": "object",
  "required": ["version", "skills"],
  "properties": {
    "version": { "type": "integer" },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "tier", "path", "tags", "description", "dependencies"],
        "properties": {
          "name": { "type": "string" },
          "tier": { "type": "integer", "enum": [1, 2, 3] },
          "path": { "type": "string" },
          "tags": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 3
          },
          "description": { "type": "string" },
          "dependencies": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      },
      "minItems": 1
    }
  },
  "additionalProperties": false
}
