      "paths": ["assets/canvas-fonts/"],
      "destPrefix": "skills/tier-1/ui-styling/",
      "defaultInstall": false,
      "cost": "heavy",
      "stability": "stable"
    },
    {
      "id": "hooks-essential",
      "kind": "hooks",
      "description": "Essential hooks — security, formatting, type checking",
      "paths": ["hooks/"],
      "defaultInstall": true,
      "cost": "light",
      "stability": "stable"
    },
    {
      "id": "workflows",
      "kind": "workflows",
      "description": "Development workflows and rules",
      "paths": ["workflows/"],
      "defaultInstall": true,
      "cost": "light",
      "stability": "stable"
    }
