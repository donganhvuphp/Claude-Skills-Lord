{
  "version": 3,
  "modules": [
    {
      "id": "agents",
      "kind": "agents",
      "description": "All 22 agents — planner, code-reviewer, debugger, architect, security, scout, and more",
      "paths": ["agents/"],
      "defaultInstall": true,
      "cost": "medium",
      "stability": "stable"
    },
    {
      "id": "commands",
      "kind": "commands",
      "description": "All commands — plan, code, test, fix, cook, design, bootstrap, and more",
      "paths": ["commands/"],
      "defaultInstall": true,
      "cost": "light",
      "stability": "stable"
    },
    {
      "id": "skills",
      "kind": "skills",
      "description": "All 67 skills — debugging, testing, frontend/backend, databases, security, UI/UX, patterns, and more",
      "paths": ["skills/"],
      "defaultInstall": true,
      "cost": "medium",
      "stability": "stable"
    },
    {
      "id": "canvas-fonts",
      "kind": "assets",
      "description": "Canvas design fonts — 81 bundled font files for poster/visual generation",
      "paths": ["assets/canvas-fonts/"],
      "destPrefix": "skills/ui-styling/",
      "defaultInstall": false,
      "cost": "heavy",
      "stability": "stable"
    },
    {
      "id": "hooks-essential",
      "kind": "hooks",
      "description": "Essential hooks — security, formatting, type checking, notifications",
      "paths": ["hooks/"],
      "defaultInstall": true,
      "cost": "light",
      "stability": "stable"
    },
    {
      "id": "workflows",
      "kind": "workflows",
      "description": "Development workflows, rules, and orchestration protocols",
      "paths": ["workflows/"],
      "defaultInstall": true,
      "cost": "light",
      "stability": "stable"
    }
  ]
}
