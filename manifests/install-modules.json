{
  "version": 4,
  "modules": [
    {
      "id": "agents",
      "kind": "agents",
      "description": "All 43 agents — planner, architect, code-reviewer, security, language-specific reviewers & build resolvers, and more",
      "paths": ["agents/"],
      "defaultInstall": true,
      "cost": "medium",
      "stability": "stable"
    },
    {
      "id": "commands",
      "kind": "commands",
      "description": "All 114 commands — plan, code, test, fix, cook, design, bootstrap, multi-*, session, build, review, and more",
      "paths": ["commands/"],
      "defaultInstall": true,
      "cost": "light",
      "stability": "stable"
    },
    {
      "id": "skills",
      "kind": "skills",
      "description": "All 165 skills — debugging, testing, frontend/backend, databases, security, UI/UX, patterns, languages, frameworks, and more",
      "paths": ["skills/"],
      "defaultInstall": true,
      "cost": "medium",
      "stability": "stable"
    },
    {
      "id": "rules",
      "kind": "rules",
      "description": "Language-specific coding rules — 11 languages (TypeScript, Python, Go, Rust, Java, Kotlin, C++, C#, PHP, Perl, Swift) + common",
      "paths": ["rules/"],
      "defaultInstall": true,
      "cost": "light",
      "stability": "stable"
    },
    {
      "id": "contexts",
      "kind": "contexts",
      "description": "Context definitions for dev, research, and review workflows",
      "paths": ["contexts/"],
      "defaultInstall": true,
      "cost": "light",
      "stability": "stable"
    },
    {
      "id": "mcp-configs",
      "kind": "mcp",
      "description": "Pre-configured MCP server definitions",
      "paths": ["mcp-configs/"],
      "defaultInstall": false,
      "cost": "light",
      "stability": "stable"
    },
    {
      "id": "canvas-fonts",
      "kind": "assets",
      "description": "Canvas design fonts — 81 bundled font files for poster/visual generation",
      "paths": ["assets/canvas-fonts/"],
      "destPrefix": "skills/ui-styling/",
      "defaultInstall": false,
      "cost": "heavy",
      "stability": "stable"
    },
    {
      "id": "hooks-essential",
      "kind": "hooks",
      "description": "Essential hooks — security, formatting, type checking, notifications",
      "paths": ["hooks/", "scripts/lib/"],
      "defaultInstall": true,
      "cost": "light",
      "stability": "stable"
    },
    {
      "id": "workflows",
      "kind": "workflows",
      "description": "Development workflows, rules, and orchestration protocols",
      "paths": ["workflows/"],
      "defaultInstall": true,
      "cost": "light",
      "stability": "stable"
    }
  ]
}
