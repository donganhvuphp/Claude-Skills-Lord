# CSL Hook Configuration
# Copy to .env and fill in values

# Discord Notification (optional)
# Get webhook URL: Discord Server Settings > Integrations > Webhooks > New Webhook
DISCORD_WEBHOOK_URL=

# Telegram Notification (optional)
# Get bot token: https://t.me/BotFather → /newbot
# Get chat ID: https://api.telegram.org/bot<token>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Hook Profile: minimal | standard (default) | strict
# minimal: only essential hooks (block-no-verify, session-end)
# standard: + quality gate, console.log check, notifications
# strict: + auto-format, typecheck, config protection
CSL_HOOK_PROFILE=standard
