{
  "version": 2,
  "modules": [
    {
      "id": "agents",
      "kind": "agents",
      "description": "All 22 agents — planner, code-reviewer, debugger, architect, security, scout, and more",
      "paths": ["agents/"],
      "defaultInstall": true,
      "cost": "medium",
      "stability": "stable"
    },
    {
      "id": "commands",
      "kind": "commands",
      "description": "All commands — plan, code, test, fix, cook, design, bootstrap, and more",
      "paths": ["commands/"],
      "defaultInstall": true,
      "cost": "light",
      "stability": "stable"
    },
    {
      "id": "skills-tier-1",
      "kind": "skills",
      "description": "Core skills — debugging, testing, frontend/backend, databases, security, UI/UX design intelligence",
      "paths": ["skills/tier-1/"],
      "defaultInstall": true,
      "cost": "medium",
      "stability": "stable"
    },
    {
      "id": "skills-tier-2",
      "kind": "skills",
      "description": "On-demand skills — auth, payments, CI/CD, patterns, MCP, design-system, brand",
      "paths": ["skills/tier-2/"],
      "defaultInstall": false,
      "cost": "medium",
      "stability": "stable"
    },
    {
      "id": "skills-tier-3",
      "kind": "skills",
      "description": "Specialty skills — language-specific patterns, niche frameworks, banners, slides",
      "paths": ["skills/tier-3/"],
      "defaultInstall": false,
      "cost": "medium",
      "stability": "beta"
    },
    {
      "id": "canvas-fonts",
      "kind": "assets",
